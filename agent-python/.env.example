LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
AGENT_NAME=ai-interview-agent
INTERVIEW_AGENT_NAME=ai-interview-agent
MONGODB_URI=mongodb://localhost:27017/ai_calling
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key

# Runtime provider defaults (payload override -> client config -> env fallback)
DEFAULT_LLM_PROVIDER=xai
DEFAULT_LLM_MODEL=grok-4-1-fast-non-reasoning
DEFAULT_STT_PROVIDER=deepgram
DEFAULT_STT_MODEL=nova-3
DEFAULT_TTS_PROVIDER=deepgram
DEFAULT_TTS_MODEL=aura-asteria-en
DEFAULT_TTS_VOICE=athena

# Optional avatar output (LiveKit official virtual avatar plugin: Simli)
# Set ENABLE_AVATAR=true to route agent audio through avatar worker.
ENABLE_AVATAR=false
AVATAR_PROVIDER=simli
# SIMLI_API_KEY=your_simli_api_key
# SIMLI_FACE_ID=your_simli_face_id
# SIMLI_EMOTION_ID=your_optional_simli_emotion_id

# Provider keys (optional if passed via client config)
# OPENAI_API_KEY=your_openai_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPGRAM_API_KEY=your_deepgram_api_key
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# CARTESIA_API_KEY=your_cartesia_api_key
# INWORLD_API_KEY=your_inworld_api_key
# Optional: fallback for Sarvam STT/TTS when client config has no API key
# SARVAM_API_KEY=your_sarvam_api_key
# Optional: fallback for xAI (Grok) LLM/TTS when client config has no API key
# XAI_API_KEY=your_xai_api_key
# Optional: fallback for Murf AI TTS when client config has no API key
# MURF_API_KEY=your_murf_api_key
