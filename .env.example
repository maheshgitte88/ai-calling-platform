# LiveKit (self-hosted)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
AGENT_NAME=ai-calling-agent

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai_calling

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Summarizer (optional - for post-call summary)
GOOGLE_API_KEY=your-gemini-key
GEMINI_API_KEY=your-gemini-key

# Runtime provider defaults (payload override -> client config -> env fallback)
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
DEFAULT_STT_PROVIDER=deepgram
DEFAULT_STT_MODEL=nova-3
DEFAULT_TTS_PROVIDER=deepgram
DEFAULT_TTS_MODEL=aura-2
DEFAULT_TTS_VOICE=athena

# Optional provider API keys for fallback
# OPENAI_API_KEY=your-openai-key
# XAI_API_KEY=your-xai-key
# DEEPSEEK_API_KEY=your-deepseek-key
# DEEPGRAM_API_KEY=your-deepgram-key
# ASSEMBLYAI_API_KEY=your-assemblyai-key
# ELEVENLABS_API_KEY=your-elevenlabs-key
# CARTESIA_API_KEY=your-cartesia-key
# INWORLD_API_KEY=your-inworld-key
# SARVAM_API_KEY=your-sarvam-key

# Server
PORT=4040

# Limits
CAMPAIGN_CONCURRENCY=5
MAX_CALL_SECONDS=300
