# Server-side LiveKit API/WebSocket (from backend/agent containers use Docker DNS, e.g. ws://livekit:7880)
LIVEKIT_URL=ws://localhost:7880
# URL the candidate browser uses to signal/WebRTC. MUST be reachable from the user's machine.
# If LIVEKIT_URL=ws://livekit:7880 (Docker), omitting this now defaults to ws://127.0.0.1:7880 for browsers.
# If LiveKit runs on another host, set explicitly, e.g. ws://YOUR_LAN_IP:7880 or wss://livekit.example.com
# LIVEKIT_PUBLIC_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Set false when you have no LiveKit egress worker (avoids 503 "no response from servers" on RoomComposite).
# INTERVIEW_RECORDING_ENABLED=false
AGENT_NAME=ai-interview-agent
INTERVIEW_AGENT_NAME=ai-interview-agent
MONGODB_URI=mongodb://localhost:27017/ai_calling
PORT=4040
APP_BASE_URL=http://localhost:3000
# Optional. If omitted, LIVEKIT_API_SECRET is used for join token signing.
# INTERVIEW_JOIN_TOKEN_SECRET=change-me

# Runtime provider defaults (payload override -> client config -> env fallback)
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
DEFAULT_STT_PROVIDER=deepgram
DEFAULT_STT_MODEL=nova-3
DEFAULT_TTS_PROVIDER=deepgram
DEFAULT_TTS_MODEL=aura-asteria-en
DEFAULT_TTS_VOICE=athena
